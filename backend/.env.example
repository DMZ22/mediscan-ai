DEBUG=True
SECRET_KEY=your-very-secret-key-change-this-in-production-min-50-chars
DB_NAME=mediscan_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin registration secret code (default: 12345678)
ADMIN_SECRET_CODE=12345678

# Frontend URL (for password reset emails)
FRONTEND_URL=http://localhost:5173

# Brevo email service
BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=noreply@yourdomain.com
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-brevo-smtp-user
EMAIL_HOST_PASSWORD=your-brevo-smtp-password
DEFAULT_FROM_EMAIL=MediScan AI <noreply@yourdomain.com>

# Google Gemini AI (free tier: https://ai.google.dev/)
# Single key:
GEMINI_API_KEY=your-gemini-api-key
# Multiple keys for load balancing + failover (comma-separated):
# GEMINI_API_KEYS=key1,key2,key3

# OpenFDA Drug API (optional — works without keys at 40 req/min, 240 req/min with key)
# OPENFDA_API_KEY=your-openfda-api-key
# OPENFDA_API_KEYS=key1,key2
